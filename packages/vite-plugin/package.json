{
  "name": "@graphics-icon/vite-umbrella",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "private": true,
  "description": "Internal: the umbrella Vite plugin (graphicsIcon) composing colorfont/svg/bitmap/imagemin. Published surface is `graphics-icon` (packages/exports), which re-exports this at graphics-icon/vite.",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "dependencies": {
    "@codejoo/colorfont": "workspace:*",
    "bitmap-icons": "workspace:*",
    "svg-icons": "workspace:*",
    "@codejoo/imagemin": "workspace:*",
    "@codejoo/unused": "workspace:*"
  },
  "peerDependencies": {
    "vite": "^5 || ^6 || ^7 || ^8"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.6.0",
    "vite": "catalog:"
  }
}
